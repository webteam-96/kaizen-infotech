<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS config for the Next.js standalone server, using HttpPlatformHandler.
  IIS launches "node server.js", assigns it a private port (%HTTP_PLATFORM_PORT%),
  and reverse-proxies all requests to it.

  PREREQUISITES on the server:
    1. Node.js LTS installed (default path assumed below: C:\Program Files\nodejs\node.exe).
    2. IIS "HttpPlatformHandler" module installed:
       https://www.iis.net/downloads/microsoft/httpplatformhandler
    3. The app-pool identity must have Read/Execute on this folder and Write on .\logs.

  If Node is installed elsewhere, update processPath below.
  For the contact form / captcha to work, set the env vars (see README-DEPLOY.txt)
  either here in <environmentVariables> or as system environment variables.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpplatformhandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" requireAccess="Script" />
    </handlers>
    <httpPlatform processPath="C:\Program Files\nodejs\node.exe"
                  arguments=".\server.js"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\node.log"
                  startupTimeLimit="120"
                  startupRetryCount="3"
                  processesPerApplication="1">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="HOSTNAME" value="127.0.0.1" />
        <environmentVariable name="NODE_ENV" value="production" />
        <!-- Contact form (optional; leave commented to disable email/captcha):
        <environmentVariable name="RESEND_API_KEY" value="" />
        <environmentVariable name="CONTACT_TO" value="" />
        <environmentVariable name="CONTACT_FROM" value="" />
        <environmentVariable name="CAPTCHA_SECRET" value="" />
        -->
      </environmentVariables>
    </httpPlatform>
    <!-- Let Node serve everything; don't let IIS intercept extension-less URLs. -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- ══════════════════════════════════════════════════════════════════════
         PERFORMANCE / CANONICAL  (recommended — see README-DEPLOY.txt "PERFORMANCE")
         Both blocks are COMMENTED OUT on purpose: each needs an IIS module that may
         not be installed, and enabling one before its module is present throws an
         HTTP 500.19 config error. Install the module (README), then uncomment.
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- (1) CANONICAL HOST — 301-redirect www → apex (kaizeninfotech.com) BEFORE the
         request reaches Node, so there is one indexed host and no redirect hop
         through the app. Requires the "URL Rewrite" module:
         https://www.iis.net/downloads/microsoft/url-rewrite
    <rewrite>
      <rules>
        <rule name="www-to-apex" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTP_HOST}" pattern="^www\.kaizeninfotech\.com$" />
          </conditions>
          <action type="Redirect" url="https://kaizeninfotech.com/{R:1}" redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>
    -->

    <!-- (2) WARM START — right after the app pool starts or recycles, IIS sends a
         request to "/" so Node boots immediately instead of on the first real
         visitor. This is the primary cure for the ~1.9s cold-start TTFB. Requires
         the "Application Initialization" IIS role feature AND the app pool set to
         startMode=AlwaysRunning with the site's preloadEnabled=true (see README).
    <applicationInitialization doAppInitAfterRestart="true">
      <add initializationPage="/" />
    </applicationInitialization>
    -->
  </system.webServer>
</configuration>
