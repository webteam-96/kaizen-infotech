# ------------------------------------------------------------------------------
# Environment variables the Kaizen Infotech site understands.
#
# On IIS (Option A) set these as <environmentVariable> entries in web.config;
# for start.bat (Option B) set them with `set NAME=value` lines. The
# package-iis.ps1 script can bake RESEND_API_KEY / CAPTCHA_SECRET in for you
# via -ResendKey / -CaptchaSecret.
# ------------------------------------------------------------------------------

# --- Contact form (Resend email) ----------------------------------------------
# Without RESEND_API_KEY the /api/contact endpoint cannot send email.
RESEND_API_KEY=
# Recipient + sender for contact-form emails (defaults shown).
CONTACT_TO=connect@kaizeninfotech.com
CONTACT_FROM=Kaizen Website <onboarding@resend.dev>

# --- CAPTCHA ------------------------------------------------------------------
# Secret used to sign captcha tokens. The built-in default is public in the
# repo, so ALWAYS override it in production (any long random string).
CAPTCHA_SECRET=

# --- Blog admin (/admin/blogs) ------------------------------------------------
# Token required by the admin write API (x-admin-token header). Falls back to
# NEXT_PUBLIC_ADMIN_PASSWORD, then to the built-in default "kaizen-admin-2026".
ADMIN_TOKEN=
NEXT_PUBLIC_ADMIN_PASSWORD=

# --- Blog storage backend (serverless hosts ONLY) -----------------------------
# Leave these unset on IIS / self-hosted Windows: the default file backend
# (public/data/blogs.json) is correct there. Only needed on read-only hosts
# like Vercel, where admin edits must go to Vercel KV / Upstash Redis instead.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
